# OpenAI API key used by AsyncOpenAI (format: sk-...)
OPENAI_API_KEY=sk-your-openai-key
# Supabase transaction pooler DSN for runtime queries (PostgreSQL URL on port 6543)
DATABASE_URL=postgresql://postgres.project-ref:your-password@aws-0-your-region.pooler.supabase.com:6543/postgres
# Supabase direct DSN for schema/init only (PostgreSQL URL on port 5432)
DATABASE_DIRECT_URL=postgresql://postgres:your-password@db.project-ref.supabase.co:5432/postgres
# Local persistent directory for ChromaDB files (path format: ./chroma_db)
CHROMA_PATH=./chroma_db
# Root directory for ingestion input/output data folders (path format: ./data)
DATA_DIR=./data
# Minimum PostgreSQL pool size as an integer (example: 2)
POOL_MIN=2
# Maximum PostgreSQL pool size as an integer (example: 10)
POOL_MAX=10
